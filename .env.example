# LLM provider selector:
#   openai | deepseek | qwen | moonshot | openrouter | groq | ollama | custom
MULTI_AGENT_TEAM_LLM_PROVIDER=openai

# Auth mode: auto | api_key | codex_auth
# Note: codex_auth is only available when MULTI_AGENT_TEAM_LLM_PROVIDER=openai.
# MULTI_AGENT_TEAM_LLM_AUTH_MODE=auto

# API key resolution priority:
# 1) MULTI_AGENT_TEAM_PROVIDER_<PROVIDER>_API_KEY
# 2) MULTI_AGENT_TEAM_LLM_API_KEY
# 3) provider native env (e.g. DEEPSEEK_API_KEY)
# 4) OPENAI_API_KEY (legacy + compatibility fallback)
#
# Recommended: set provider-scoped key.
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_DEEPSEEK_API_KEY=<YOUR_DEEPSEEK_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_QWEN_API_KEY=<YOUR_DASHSCOPE_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_MOONSHOT_API_KEY=<YOUR_MOONSHOT_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_GROQ_API_KEY=<YOUR_GROQ_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_OLLAMA_API_KEY=<YOUR_OLLAMA_API_KEY>
# MULTI_AGENT_TEAM_PROVIDER_CUSTOM_API_KEY=<YOUR_CUSTOM_API_KEY>
#
# Note: local Ollama usually does not require API key. This variable is optional.
#
# Optional generic key:
# MULTI_AGENT_TEAM_LLM_API_KEY=<YOUR_API_KEY>
#
# Legacy/compat fallback:
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Base URL resolution priority:
# 1) MULTI_AGENT_TEAM_PROVIDER_<PROVIDER>_BASE_URL
# 2) MULTI_AGENT_TEAM_LLM_BASE_URL
# 3) MULTI_AGENT_TEAM_OPENAI_BASE_URL / OPENAI_BASE_URL
#
# Provider-scoped examples:
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_BASE_URL=
# MULTI_AGENT_TEAM_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MULTI_AGENT_TEAM_PROVIDER_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# MULTI_AGENT_TEAM_PROVIDER_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MULTI_AGENT_TEAM_PROVIDER_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# MULTI_AGENT_TEAM_PROVIDER_GROQ_BASE_URL=https://api.groq.com/openai/v1
# MULTI_AGENT_TEAM_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
#
# Optional generic endpoint:
# MULTI_AGENT_TEAM_LLM_BASE_URL=https://<YOUR_COMPANY_API_BASE>/v1
#
# Optional OpenAI-compatible alias:
# MULTI_AGENT_TEAM_OPENAI_BASE_URL=https://<YOUR_COMPANY_API_BASE>/v1

# TLS CA cert resolution:
# MULTI_AGENT_TEAM_PROVIDER_<PROVIDER>_CA_CERT_PATH -> MULTI_AGENT_TEAM_LLM_CA_CERT_PATH -> MULTI_AGENT_TEAM_CA_CERT_PATH
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_CA_CERT_PATH=/absolute/path/to/your-company-root-ca.cer
# MULTI_AGENT_TEAM_LLM_CA_CERT_PATH=/absolute/path/to/your-company-root-ca.cer
# MULTI_AGENT_TEAM_CA_CERT_PATH=/absolute/path/to/your-company-root-ca.cer

# Responses API toggle resolution:
# MULTI_AGENT_TEAM_PROVIDER_<PROVIDER>_USE_RESPONSES_API -> MULTI_AGENT_TEAM_LLM_USE_RESPONSES_API -> MULTI_AGENT_TEAM_USE_RESPONSES_API
# Most enterprise gateways are better with Chat Completions / tools semantics
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_USE_RESPONSES_API=false
# MULTI_AGENT_TEAM_LLM_USE_RESPONSES_API=false
# MULTI_AGENT_TEAM_USE_RESPONSES_API=false

# Optional settings
# MULTI_AGENT_TEAM_DEFAULT_MODEL=gpt-5.1-chat
# MULTI_AGENT_TEAM_MODEL_FALLBACKS=gpt-5.1-codex-mini,gpt-5.1-chat
# MULTI_AGENT_TEAM_MODEL_COOLDOWN_BASE_SEC=60
# MULTI_AGENT_TEAM_MODEL_COOLDOWN_MAX_SEC=3600
# MULTI_AGENT_TEAM_SUMMARY_MODEL=gpt-5.1-chat
# MULTI_AGENT_TEAM_SUMMARY_MODE=gpt-5.1-chat
# MULTI_AGENT_TEAM_TEMPERATURE=
# MULTI_AGENT_TEAM_LLM_TEMPERATURE=
# MULTI_AGENT_TEAM_PROVIDER_OPENAI_TEMPERATURE=
# MULTI_AGENT_TEAM_SUMMARY_TRIGGER_TURNS=2000
# MULTI_AGENT_TEAM_MAX_CONTEXT_TURNS=2000
# MULTI_AGENT_TEAM_MAX_ATTACHMENT_CHARS=1000000
# MULTI_AGENT_TEAM_MAX_UPLOAD_MB=200
# MULTI_AGENT_TEAM_ALLOWED_COMMANDS=pwd,ls,cat,rg,head,tail,wc,find,echo,date,python3,git,npm,node,pytest,sed,awk,mkdir,touch,cp,mv

# File access scope
# Default extra allowed roots already include ~/Desktop/workbench and ~/Downloads
# MULTI_AGENT_TEAM_EXTRA_ALLOWED_ROOTS=/Users/<YOU>/Desktop/workbench;/Users/<YOU>/Downloads;/Users/<YOU>/Desktop
# MULTI_AGENT_TEAM_ALLOW_ANY_PATH=false

# Web fetch tool
# Leave blank to allow all domains (no restriction)
# MULTI_AGENT_TEAM_WEB_ALLOWED_DOMAINS=
# MULTI_AGENT_TEAM_WEB_FETCH_TIMEOUT_SEC=12
# MULTI_AGENT_TEAM_WEB_FETCH_MAX_CHARS=120000
# MULTI_AGENT_TEAM_WEB_CA_CERT_PATH=/absolute/path/to/corp-root-ca.cer
# MULTI_AGENT_TEAM_WEB_SKIP_TLS_VERIFY=false

# OpenClaw-inspired runtime controls
# MULTI_AGENT_TEAM_MAX_CONCURRENT_RUNS=2
# MULTI_AGENT_TEAM_RUN_QUEUE_WAIT_NOTICE_MS=1500
# MULTI_AGENT_TEAM_EXECUTION_MODE=host
# MULTI_AGENT_TEAM_DOCKER_BIN=docker
# MULTI_AGENT_TEAM_DOCKER_IMAGE=python:3.11-slim
# MULTI_AGENT_TEAM_DOCKER_NETWORK=none
# MULTI_AGENT_TEAM_DOCKER_MEMORY=2g
# MULTI_AGENT_TEAM_DOCKER_CPUS=1.0
# MULTI_AGENT_TEAM_DOCKER_PIDS_LIMIT=256
# MULTI_AGENT_TEAM_DOCKER_CONTAINER_PREFIX=multi-agent-team-sbx
# MULTI_AGENT_TEAM_ENABLE_SESSION_TOOLS=true
# MULTI_AGENT_TEAM_TOOL_RESULT_SOFT_TRIM_CHARS=40000
# MULTI_AGENT_TEAM_TOOL_RESULT_HARD_CLEAR_CHARS=180000
# MULTI_AGENT_TEAM_TOOL_RESULT_HEAD_CHARS=8000
# MULTI_AGENT_TEAM_TOOL_RESULT_TAIL_CHARS=4000
# MULTI_AGENT_TEAM_TOOL_CONTEXT_PRUNE_KEEP_LAST=3

# Note: all project-prefixed env keys are standardized as MULTI_AGENT_TEAM_*.
